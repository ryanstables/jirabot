# Jira
JIRA_HOST=your-org.atlassian.net
JIRA_AGENT_EMAIL=agent@company.com
JIRA_API_TOKEN=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Anthropic
ANTHROPIC_API_KEY=

# Redis — local Docker: redis://localhost:6379 (docker-compose sets this automatically)
REDIS_URL=redis://localhost:6379

# Webhook receiver
JIRA_WEBHOOK_SECRET=

# Agent user ID (Jira accountId)
JIRA_AGENT_ACCOUNT_ID=

# V2: Slack integration (optional — omit to disable Slack features)
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=

# V2: Cron schedule for self-assignment scanning (default: every 5 minutes)
# Uses standard cron syntax: minute hour day month weekday
SCAN_CRON_SCHEDULE=*/5 * * * *

# V2: Boards config — see README for full schema including v2 fields
# BOARDS_CONFIG=[{"jiraProject":"PROJ","githubRepo":"org/repo","defaultBranch":"main","targetStatus":"Ready for Review","escalationStatus":"Needs Clarity","autoAssignJql":"project = PROJ AND assignee is EMPTY AND labels = agent-eligible AND status = 'To Do'","slackChannel":"C012AB3CD","secondaryRepos":[]}]
