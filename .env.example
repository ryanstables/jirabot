# Jira
JIRA_HOST=your-org.atlassian.net
JIRA_AGENT_EMAIL=agent@company.com
JIRA_API_TOKEN=
JIRA_AGENT_ACCOUNT_ID=
JIRA_WEBHOOK_SECRET=

# GitHub — choose ONE of the two options below:

# Option 1: Personal Access Token (simpler — recommended for local dev)
# Create at: https://github.com/settings/tokens/new → select 'repo' scope
GITHUB_PAT=

# Option 2: GitHub App (recommended for production)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_INSTALLATION_ID=

# Anthropic
ANTHROPIC_API_KEY=

# Redis — docker-compose overrides this automatically
REDIS_URL=redis://localhost:6379

# Boards config (JSON array)
BOARDS_CONFIG=[{"jiraProject":"PROJ","githubRepo":"org/repo","defaultBranch":"main","targetStatus":"Ready for Review","escalationStatus":"Needs Clarity"}]

# Slack integration (optional — omit to disable)
# SLACK_BOT_TOKEN=xoxb-
# SLACK_SIGNING_SECRET=

# Cron schedule for self-assignment scanning (default: every 5 minutes)
# SCAN_CRON_SCHEDULE=*/5 * * * *
